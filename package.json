{
  "name": "uandi",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,css,md}\"",
    "test:e2e": "pnpm --filter web test:e2e",
    "test:e2e:visible": "pnpm --filter web test:e2e:visible",
    "test:e2e:ui": "pnpm --filter web test:e2e:ui",
    "emulators": "npm --prefix functions run build && firebase emulators:start --only auth,firestore,storage,functions",
    "play:listing:pull": "node scripts/play-listing.mjs pull",
    "play:listing:push": "node scripts/play-listing.mjs push",
    "play:notes:pull": "node scripts/play-release-notes.mjs pull",
    "play:notes:push": "node scripts/play-release-notes.mjs push",
    "screenshots": "pnpm --filter web screenshots"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "firebase-admin": "^13.7.0",
    "firebase-tools": "^15.8.0",
    "googleapis": "^173.0.0",
    "pretendard": "^1.3.9",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "turbo": "^2.3.3"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "~19.1.0",
      "@types/react-dom": "~19.1.0",
      "react": "19.1.0",
      "react-dom": "19.1.0"
    }
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  }
}
