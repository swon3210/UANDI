// TODO: 스토리지 보안 규칙 구현
// 구현 명세: docs/03-domain-models.md

rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 커플 사진
    match /couples/{coupleId}/photos/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // 가계부 배경 이미지 (유저 개인)
    match /users/{userId}/cashbook/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
