# EAS Build ignore — based on .gitignore, but includes google-services.json
# so EAS can configure Firebase Android during cloud build.

# dependencies
node_modules/

# Expo
.expo/
dist/
web-build/
expo-env.d.ts

# Native
.kotlin/
*.orig.*
*.jks
*.p8
*.p12
*.key
*.mobileprovision

# Metro
.metro-health-check*

# debug
npm-debug.*
yarn-debug.*
yarn-error.*

# macOS
.DS_Store
*.pem

# local env files
.env*.local

# typescript
*.tsbuildinfo

app-example

# generated native folders — EAS regenerates these during build
/ios
/android

# iOS Firebase config not used in this Android build
GoogleService-Info.plist

# NOTE: google-services.json is intentionally NOT ignored here.
# It's still git-ignored (see .gitignore) but must be uploaded to EAS Build.
