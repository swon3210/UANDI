{
  "expo": {
    "name": "말랑 가계부",
    "slug": "my-react-native-app",
    "version": "1.3.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "uandi",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.swon3210.uandi",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "영수증을 직접 촬영해 내역을 추가하기 위해 카메라를 사용합니다.",
        "NSPhotoLibraryUsageDescription": "영수증 사진을 첨부해 내역을 추가하기 위해 사진에 접근합니다."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FEF3F2",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.swon3210.uandi",
      "googleServicesFile": "./google-services.json",
      "permissions": ["NOTIFICATIONS", "POST_NOTIFICATIONS", "CAMERA"],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "uandi-web.vercel.app"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-native.png",
          "imageWidth": 260,
          "resizeMode": "contain",
          "backgroundColor": "#FAFAF8",
          "dark": {
            "image": "./assets/images/splash-native.png",
            "imageWidth": 260,
            "resizeMode": "contain",
            "backgroundColor": "#FAFAF8"
          }
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#E8837A",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0de212de-7fe9-45d0-9a52-6ac42634b83a"
      }
    },
    "owner": "swon3210"
  }
}
