// 명세: docs/03-domain-models.md (Firestore 보안 규칙 명세) + docs/08-spaces.md (두 공간)
// - 우리집 영역: couples/{coupleId}/<영역> — 커플 멤버 공동
// - 재테크 원본: couples/{coupleId}/sideHustles/{uid}/<영역> — 본인만
// - 재테크 합산: couples/{coupleId}/meta/outerSummary — 커플 멤버 read, v1.1에서 byUser[uid] write 검증 추가 예정

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function isCoupleMember(coupleId) {
      return isAuthed() &&
        request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.memberUids;
    }

    // ── 사용자 본인 데이터 ───────────────────────────────────────
    match /users/{uid} {
      allow read, write: if isAuthed() && request.auth.uid == uid;

      // users/{uid}/fcmTokens 등 본인 하위
      match /{document=**} {
        allow read, write: if isAuthed() && request.auth.uid == uid;
      }
    }

    // ── 커뮤니티 (전역 공유 — couples/ 격리 예외) ────────────────
    // 명세: docs/pages/community/community-feed.md
    // - 모든 로그인 유저가 승인된 글만 읽기 가능
    // - 클라이언트 쓰기는 Phase 3(user 생성), Phase 4(본인 삭제, 신고)에서 추가
    // - scraped 생성·상태 변경은 영구적으로 Admin SDK(서버)만
    match /communityPosts/{postId} {
      allow read: if isAuthed() && resource.data.status == 'published';
      // 클라이언트 write는 v1 Phase 2에서는 일체 불가. Admin SDK 시드는 owner 헤더로 우회.

      // 신고 서브컬렉션 — Phase 4에서 본격 도입. 현재는 클라이언트 쓰기 차단.
      match /reports/{reporterUid} {
        allow read, write: if false;
      }
    }

    // ── 커플 ──────────────────────────────────────────────────────
    match /couples/{coupleId} {
      // 커플 문서 자체
      // 생성: 인증된 본인이 초대 코드로 만들거나 합류할 때 클라이언트가 직접 쓸 수 있어야 함
      // 단순화를 위해 인증된 사용자는 create 가능, 그 외는 멤버만
      allow create: if isAuthed();
      allow read, update, delete: if isCoupleMember(coupleId);

      // 🏠 우리집 — 커플 공동 (멤버 누구나 읽기/쓰기)
      match /folders/{document=**} {
        allow read, write: if isCoupleMember(coupleId);
      }
      match /photos/{document=**} {
        allow read, write: if isCoupleMember(coupleId);
      }
      match /cashbookEntries/{document=**} {
        allow read, write: if isCoupleMember(coupleId);
      }
      match /cashbookCategories/{document=**} {
        allow read, write: if isCoupleMember(coupleId);
      }
      match /annualPlans/{document=**} {
        allow read, write: if isCoupleMember(coupleId);
      }

      // 재테크 합산 요약 (couples/{id}/meta/outerSummary 등)
      // v1: 커플 멤버 read/write 허용 (단순화)
      // v1.1 TODO: outerSummary write 시 request.auth.uid == byUser 변경 키로 제한
      match /meta/{document=**} {
        allow read, write: if isCoupleMember(coupleId);
      }

      // 💼 재테크 원본 (v1.1 컬렉션) — sideHustles/{uid}/<영역>
      // 위치는 couples/ 하위지만 접근은 본인만. 다른 멤버가 본 영역 접근 시도해도 deny.
      match /sideHustles/{uid} {
        allow read, write:
          if isCoupleMember(coupleId) && request.auth.uid == uid;

        match /{document=**} {
          allow read, write:
            if isCoupleMember(coupleId) && request.auth.uid == uid;
        }
      }
    }
  }
}
