// 명세: docs/03-domain-models.md (Firestore 보안 규칙 명세) + docs/08-spaces.md (두 공간)
// - 우리집 영역: couples/{coupleId}/<영역> — 커플 멤버 공동
// - 재테크 원본: couples/{coupleId}/sideHustles/{uid}/<영역> — 본인만
// - 재테크 합산: couples/{coupleId}/meta/outerSummary — 커플 멤버 read, v1.1에서 byUser[uid] write 검증 추가 예정

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() {
      return request.auth != null;
    }

    function isCoupleMember(coupleId) {
      return isAuthed() &&
        request.auth.uid in get(/databases/$(database)/documents/couples/$(coupleId)).data.memberUids;
    }

    // ── 사용자 본인 데이터 ───────────────────────────────────────
    match /users/{uid} {
      allow read, write: if isAuthed() && request.auth.uid == uid;

      // users/{uid}/fcmTokens 등 본인 하위
      match /{document=**} {
        allow read, write: if isAuthed() && request.auth.uid == uid;
      }
    }

    // ── 커뮤니티 (전역 공유 — couples/ 격리 예외) ────────────────
    // 명세: docs/pages/community/community-feed.md
    // - 모든 로그인 유저가 승인된 글만 읽기 가능
    // - user 글 create: 본인 작성 + status=published + reportCount=0 + source 없음
    // - user 글 update: 본인 글에 한해 body/imageUrl/editedAt만 변경 가능
    //   (affectedKeys.hasOnly로 status/reportCount/author/type/시각 변조 차단)
    // - user 글 delete: 본인만
    // - scraped 생성·상태 변경(hidden 등)은 영구적으로 Admin SDK(서버)만
    match /communityPosts/{postId} {
      allow read: if isAuthed() && resource.data.status == 'published';

      allow create: if isAuthed()
        && request.resource.data.type == 'user'
        && request.resource.data.status == 'published'
        && request.resource.data.author.uid == request.auth.uid
        && request.resource.data.reportCount == 0
        && !('source' in request.resource.data);

      // 본인 글 수정 — 변경 키를 본문/이미지/수정시각으로만 한정.
      // hasOnly는 부분집합도 허용하므로 imageUrl 미변경(본문만 수정)도 통과한다.
      allow update: if isAuthed()
        && resource.data.author.uid == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['body', 'imageUrl', 'editedAt'])
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 1000;

      allow delete: if isAuthed() && resource.data.author.uid == request.auth.uid;

      // 신고 서브컬렉션
      // - create: 본인 uid 문서만(중복 신고 방지: 문서 id == uid)
      // - update/delete: 클라이언트 불가(신고 철회 UI 없음 + 임의 조작 방지)
      // - read: 클라이언트 불가(누적은 서버 트리거의 reportCount로만 노출)
      match /reports/{reporterUid} {
        allow read: if false;
        allow create: if isAuthed()
          && request.auth.uid == reporterUid
          && request.resource.data.reason is string
          && request.resource.data.reason.size() > 0
          && request.resource.data.reason.size() < 50;
        allow update, delete: if false;
      }
    }

    // ── 관리자 식별 ───────────────────────────────────────────────
    // admins/{uid} 문서가 존재하면 해당 uid는 admin.
    // - 본인의 admin 여부만 클라이언트가 read 가능 (UI 가드용)
    // - 추가/제거는 Firebase 콘솔/Admin SDK로만
    match /admins/{uid} {
      allow read: if isAuthed() && request.auth.uid == uid;
      allow write: if false;
    }

    // ── 초대 코드 인덱스 (couples/ 격리 예외) ─────────────────────
    // inviteCodes/{code} → { coupleId, createdBy, expiresAt, consumedBy, createdAt }
    // - couples/* read는 멤버 제한이라 신규 유저가 코드→couple 조회 불가 → 별도 인덱스로 해결
    // - get만 허용 (list 금지) — 6자리 코드를 직접 알아야 read 가능
    // - 합류는 본인 uid로 consumedBy를 설정하는 update 1회만 허용
    match /inviteCodes/{code} {
      allow get: if isAuthed();
      allow list: if false;

      allow create: if isAuthed()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.consumedBy == null
        && request.resource.data.coupleId is string
        && request.resource.data.expiresAt is timestamp;

      // 합류: 본인 uid를 consumedBy에 기입. 본인이 만든 코드는 합류 불가.
      // consumedBy 외 필드는 수정 금지.
      allow update: if isAuthed()
        && resource.data.consumedBy == null
        && request.resource.data.consumedBy == request.auth.uid
        && resource.data.createdBy != request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['consumedBy']);

      // 만든 사람만 삭제 가능 (커플 연결 완료 후 정리)
      allow delete: if isAuthed() && resource.data.createdBy == request.auth.uid;
    }

    // ── 커플 ──────────────────────────────────────────────────────
    match /couples/{coupleId} {
      // 커플 문서 자체
      // 생성: 인증된 본인이 단독 멤버로만 만들 수 있음
      allow create: if isAuthed()
        && request.resource.data.memberUids.size() == 1
        && request.auth.uid in request.resource.data.memberUids;

      allow read, delete: if isCoupleMember(coupleId);

      // 업데이트:
      // - 멤버는 자유롭게 수정
      // - 비멤버는 self-join에 한해 memberUids에 본인을 추가 (size 1 → 2, memberUids 외 필드 변경 금지)
      //   coupleId는 자동 생성된 20자 ID라 추측 불가 — inviteCodes를 거쳐야만 알 수 있음
      allow update: if isCoupleMember(coupleId) ||
        (isAuthed() &&
         resource.data.memberUids.size() == 1 &&
         request.resource.data.memberUids.size() == 2 &&
         request.resource.data.memberUids.hasAll(resource.data.memberUids) &&
         request.auth.uid in request.resource.data.memberUids &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberUids']));

      // 🏠 우리집 — 커플 공동 (멤버 누구나 읽기/쓰기)
      match /folders/{document=**} {
        allow read, write: if isCoupleMember(coupleId);
      }
      match /photos/{document=**} {
        allow read, write: if isCoupleMember(coupleId);
      }
      match /cashbookEntries/{document=**} {
        allow read, write: if isCoupleMember(coupleId);
      }
      match /cashbookCategories/{document=**} {
        allow read, write: if isCoupleMember(coupleId);
      }
      match /annualPlans/{document=**} {
        allow read, write: if isCoupleMember(coupleId);
      }

      // 재테크 합산 요약 (couples/{id}/meta/outerSummary 등)
      // v1: 커플 멤버 read/write 허용 (단순화)
      // v1.1 TODO: outerSummary write 시 request.auth.uid == byUser 변경 키로 제한
      match /meta/{document=**} {
        allow read, write: if isCoupleMember(coupleId);
      }

      // 💼 재테크 원본 (v1.1 컬렉션) — sideHustles/{uid}/<영역>
      // 위치는 couples/ 하위지만 접근은 본인만. 다른 멤버가 본 영역 접근 시도해도 deny.
      match /sideHustles/{uid} {
        allow read, write:
          if isCoupleMember(coupleId) && request.auth.uid == uid;

        match /{document=**} {
          allow read, write:
            if isCoupleMember(coupleId) && request.auth.uid == uid;
        }
      }
    }
  }
}
