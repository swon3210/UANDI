rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 에뮬레이터 테스트용: 모든 접근 허용
    // 프로덕션 배포 전 반드시 아래 규칙으로 교체할 것
    match /{document=**} {
      allow read, write: if true;
    }

    // TODO: 프로덕션 규칙 (위 임시 규칙 삭제 후 활성화)
